# Bridge-Maker — required environment variables
# Copy to .env and fill in your values. .env is gitignored.

# ── Groq API ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# Scout model (fast, cheap — used for all Scout agents)
GROQ_MODEL=moonshotai/kimi-k2-instruct

# General model (used for synthesis/judgment — can be the same or smarter)
GROQ_GENERAL_MODEL=moonshotai/kimi-k2-instruct

# VLM model (must support image inputs)
GROQ_VLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Optional: Ollama local VLM ────────────────────────────────────────────────
# VLM_PROVIDER=ollama
# OLLAMA_MODEL=llava:13b
# OLLAMA_HOST=http://localhost:11434
